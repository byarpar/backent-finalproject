# ===================================
# LISU DICTIONARY - ENVIRONMENT CONFIGURATION
# ===================================

# ===================================
# Application Configuration
# ===================================
NODE_ENV=development
PORT=3001
API_VERSION=v1

# ===================================
# Frontend Configuration
# ===================================
FRONTEND_URL=http://localhost:3000

# ===================================
# Database Configuration
# ===================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lisuDict
DB_USER=byarpar
DB_PASSWORD=your_secure_password

# Database Pool Settings
DB_POOL_MIN=5
DB_POOL_MAX=25
DB_POOL_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=3000

# ===================================
# Authentication & Security
# ===================================
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

SESSION_SECRET=your_super_secret_session_key_change_in_production_min_32_chars
SESSION_MAX_AGE=86400000

# Password Hashing
BCRYPT_ROUNDS=12

# ===================================
# OAuth Configuration (Google)
# ===================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# ===================================
# Google reCAPTCHA v2 Configuration
# ===================================
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key-here

# ===================================
# Email Configuration (SMTP)
# ===================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@lisudict.com
EMAIL_FROM_NAME=Lisu Dictionary

# ===================================
# File Upload Configuration
# ===================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# ===================================
# Rate Limiting
# ===================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===================================
# Logging Configuration
# ===================================
LOG_LEVEL=info
LOG_FILE_PATH=logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14

# ===================================
# CORS Configuration
# ===================================
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ===================================
# Socket.IO Configuration
# ===================================
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# ===================================
# Cache Configuration (Optional)
# ===================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=3600

# ===================================
# Monitoring & Performance
# ===================================
ENABLE_METRICS=true
SLOW_QUERY_THRESHOLD=1000

# ===================================
# Feature Flags
# ===================================
ENABLE_EMAIL_VERIFICATION=true
ENABLE_GOOGLE_AUTH=true
ENABLE_CHAT=true
ENABLE_DISCUSSIONS=true
